# Copy to .env (gitignored) and fill in.
# Env vars used by scripts in this repo.

# OpenRouter API key — used by eval/distill_responses.py (Phase 1 of v16).
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# HuggingFace token — used by notebooks via huggingface_hub.login().
# On Kaggle, this is read from kaggle_secrets instead. Locally, set here.
# Get from https://huggingface.co/settings/tokens (write scope required for push).
HF_TOKEN=

# Kaggle credentials — needed for `kaggle datasets version` from CLI.
# On macOS, place these in ~/.kaggle/kaggle.json with mode 600 instead of using env vars.
# KAGGLE_USERNAME=
# KAGGLE_KEY=
